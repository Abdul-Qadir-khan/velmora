generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String?
  price           Float
  originalPrice   Float?
  stock           Int         @default(0)
  rating          Float       @default(0)
  category        String      // ✅ String field
  categoryId      String?     // ✅ Relation (nullable)
  categoryObj     Category?   @relation(fields: [categoryId], references: [id])
  
  isNew           Boolean     @default(false)
  bestSeller      Boolean     @default(false)
  images          String?
  
  brandId         String
  brand           Brand       @relation(fields: [brandId], references: [id])
  
  variations      Variation[]
  cartItems       CartItem[]

  seoTitle        String? @default("")
  seoDescription  String? @default("")
  seoKeywords     String? @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  logo     String?
  products Product[]
}

model Variation {
  id       String  @id @default(cuid())
  colors   String
  sizes    String
  specs    String
  
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId])
}

model CartItem {
  id             String   @id @default(cuid())
  userId         String
  productId      String
  quantity       Int      @default(1)
  selectedSize   String?
  selectedColor  String?

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, productId, selectedSize, selectedColor])
}